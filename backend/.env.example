# 必填（所有配置以本文件为准，无代码内默认）
DATABASE_URL=./youmind.db
JWT_SECRET=your-secret-here

# 可选
APP_NAME=YouMind Backend v2
APP_ENV=development
HTTP_PORT=8080
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI 兼容 API（对话用）
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4.1-mini

# 独立 AI SDK（推荐）
# 若不设置，将自动回退到 OPENAI_COMPAT_* 配置
AI_SDK_BASE_URL=https://api.openai.com/v1
# third-party key, sent as x-w6service-api-key
AI_SDK_SERVICE_API_KEY=
AI_SDK_UPLOAD_PATH=/api/upload
AI_SDK_TIMEOUT_SEC=120
AI_SDK_RETRY_MAX=2
# 设为 true 时回滚到旧的 ai.NewFromEnv 实现
AI_SDK_LEGACY_MODE=false

# W6 AI 网关配置（用于课程大纲 / 网页生成）
# 如果不使用 W6，可以留空；使用时至少需要 BASE_URL、WSS_BASE_URL 和鉴权字段。
W6_BASE_URL=https://beta.megamoyo.cn/api
W6_WSS_BASE_URL=wss://beta.megamoyo.cn/api/interact/chat/
W6_AUTH_HEADER_FIELD=x-w6-api-key
W6_AUTH_HEADER_VALUE=
W6_MODEL_PROCEDURE=raw
W6_MODEL_LLM=claude-3.7-sonnet
W6_MODEL_LLM_SHORT=Claude
W6_MODULE_NAME=w6.agent.third_party.iecube
