# AI 模型配置

# OpenRouter API Key（从 https://openrouter.ai/keys 获取）
VITE_OPENROUTER_API_KEY=your_api_key_here

# 默认模型（OpenRouter Gemini 3.1 Pro）
VITE_DEFAULT_MODEL=openrouter/google/gemini-3-pro-preview

# 备选模型
VITE_FALLBACK_MODEL=openrouter/google/gemini-3-flash-preview

# API 基础 URL
VITE_API_BASE_URL=https://openrouter.ai/api/v1
